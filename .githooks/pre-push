#!/bin/sh

set -eu

branch_name="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch_name" = "HEAD" ]; then
  echo "ERROR: detached HEAD 상태에서는 push할 수 없습니다."
  exit 1
fi

case "$branch_name" in
  main|feature/*|hotfix/*)
    ;;
  *)
    echo "ERROR: 브랜치 이름이 규칙에 맞지 않습니다: $branch_name"
    echo "Allowed: main, feature/*, hotfix/*"
    exit 1
    ;;
esac
